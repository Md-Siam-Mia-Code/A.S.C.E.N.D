{
  "name": "ascend",
  "version": "1.0.0",
  "description": "Android System Control & ENhanced Debloater",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "Your Name",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ascend.dev",
    "productName": "A.S.C.E.N.D.",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "debloat_db.json",
        "to": "debloat_db.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "assets/logo.png",
      "uninstallerIcon": "assets/logo.png",
      "installerSidebar": "build/sidebar.bmp",
      "license": "LICENSE.md"
    }
  }
}